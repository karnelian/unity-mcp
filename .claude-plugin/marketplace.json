{
  "name": "karnelian-unity-mcp",
  "owner": {
    "name": "karnelian"
  },
  "description": "Claude Code marketplace for Karnelian Unity MCP tools.",
  "version": "0.1.6",
  "plugins": [
    {
      "name": "unity-mcp",
      "displayName": "Unity MCP",
      "source": "./plugins/unity-mcp",
      "description": "Connect Claude Code to the Unity Editor through the optimized Karnelian Unity MCP server.",
      "version": "0.1.6",
      "author": {
        "name": "karnelian"
      },
      "homepage": "https://github.com/karnelian/unity-mcp",
      "repository": "https://github.com/karnelian/unity-mcp",
      "license": "MIT",
      "category": "game-development",
      "tags": ["unity", "mcp", "claude-code", "game-development"],
      "keywords": ["unity", "mcp", "claude-code", "game-development"],
      "mcpServers": {
        "karnellabs-unity-mcp": {
          "command": "npx",
          "args": [
            "-y",
            "github:karnelian/unity-mcp",
            "--profile=core"
          ],
          "env": {
            "UNITY_MCP_PROFILE": "core"
          }
        }
      }
    }
  ]
}
